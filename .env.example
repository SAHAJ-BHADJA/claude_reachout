# Copy to .env and fill in. NEVER commit the real .env (it's git-ignored).
# On Render, set these in the dashboard (Environment), not in git.

# ---- Database: local leaves blank (SQLite); cloud = Supabase Postgres URI ----
DATABASE_URL=

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_NAME=claude-opus-4-5-20251101

# ---- Hunter.io (free email source: 25 searches + 50 verifications / month) ----
HUNTER_API_KEY=
HUNTER_FETCH=10

# ---- Apollo ----
APOLLO_API_KEYS=
APOLLO_BASE_URL=https://api.apollo.io/api/v1
APOLLO_FETCH=20

# ---- Apify (needs PAID plan for API; UI-only on free) ----
APIFY_TOKEN=
APIFY_ACTOR_ID=IoSHqwTR9YGhzccez
APIFY_FETCH=30

# How many fetched leads to actually email per company
EMAIL_TOP_N=20

# ---- Gmail (OAuth) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/gmail/oauth/callback
GMAIL_SENDER_EMAIL=

# ---- Company research (optional) ----
TAVILY_API_KEY=

# ---- Public URL for the tracking pixel (your Render URL in cloud) ----
TRACKING_BASE_URL=http://127.0.0.1:8000

# ---- Cron tick protection (random string) ----
CRON_SECRET=change-me

# ---- Deliverability policy ----
SEND_TIMEZONE=America/Los_Angeles
SEND_DAYS=0,1,2,3,4
SEND_HOUR_START=9
SEND_HOUR_END=17
MIN_GAP_SECONDS=420
DAILY_HARD_CAP=50
FOLLOWUP_GAP_DAYS=3,4

# ---- Master data (resume). Local: file path. Cloud: Render Secret File path or paste MASTER_DATA_JSON ----
MASTER_DATA_PATH=master_resume_data.json
